# ticketApp environment file — example template.
# Copy to `.env` and replace placeholders with real values.
# This file IS committed to the repo (it documents the contract);
# the real `.env` is gitignored.
#
# Vars are consumed by:
#   - docker compose (local-environment/docker-ticketApp/docker-compose.yml)
#   - the opencode MCP server for SonarQube (~/.config/opencode/opencode.json)
#   - CI workflows (.github/workflows/ci-*.yml) via GitHub secrets, not this file

# --- PostgreSQL (local docker compose) ---
POSTGRES_DB=ticketAppDb
POSTGRES_USER=ticketAppUser
POSTGRES_PASSWORD=ticketAppPass
POSTGRES_PORT=6432

# --- SonarQube Cloud ---
# All three are required (no defaults; the scanner refuses to run if any is missing).
# Generate a user token at: https://sonarcloud.io/account/security
# Copy the token value (starts with `sqp_...`) into SONARQUBE_TOKEN below.
SONARQUBE_TOKEN=<your-sonarcloud-user-token>
SONARQUBE_ORG=<your-sonarcloud-organization-key>
SONARQUBE_URL=<your-sonarcloud-url># e.g. https://sonarcloud.io

# --- Google Sign-In (BFF) ---
# OAuth 2.0 Web client id from Google Cloud Console.
# Front reads the same value via front/.env.local as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# --- BFF session signing ---
# HS256 secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
BFF_JWT_SECRET=<generate-with-openssl-rand-base64-32>

# --- AI extraction (MiniMax provider, ADR 0007) ---
# Required for the scheduler to actually run. The BFF refuses to
# bind placeholders at runtime — the operator layer (this file,
# shell env, or application-local.yml) must supply every value.
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=<your-minimax-api-key>
MINIMAX_MODEL=MiniMax-M3
MINIMAX_TIMEOUT_MS=30000

# BFF-owned scheduler knobs (application.yml does not bake defaults
# for these either — supply them here, in shell env, or via the
# active profile).
TICKETAPP_AI_ENABLED=true
TICKETAPP_AI_CRON=0 */15 * * * *
TICKETAPP_AI_BATCH_SIZE=5
TICKETAPP_AI_RETRY_ATTEMPTS=2

