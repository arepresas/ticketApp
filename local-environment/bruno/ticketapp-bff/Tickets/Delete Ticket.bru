meta {
  name: Delete Ticket
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/api/tickets/{{createdTicketId}}
  body: none
  auth: bearer {{authToken}}
}

docs {
  Permanently delete a ticket and its attached file bytes.
  Returns 204 No Content on success, or 404 if the ticket doesn't exist.
  Auth-gated.
}

asserts {
  res.status: eq 204
}