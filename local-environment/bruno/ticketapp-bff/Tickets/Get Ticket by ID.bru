meta {
  name: Get Ticket by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/tickets/{{createdTicketId}}
  body: none
  auth: bearer {{authToken}}
}

docs {
  Fetch a single ticket by UUID. Returns 200 + TicketResponse JSON,
  or 404 if no row matches the id. Auth-gated.
}

asserts {
  res.status: eq 200
  res.headers["content-type"]: contains application/json
  res.body.id: eq {{createdTicketId}}
}