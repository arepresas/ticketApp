# ticketApp/front env example — copy to `front/.env.local` and fill in.
# `.env.local` is gitignored; this file IS committed (template).
#
# --- Google Identity Services ---
# OAuth 2.0 client id from Google Cloud Console (Web application).
# Required origins: http://localhost:5173 (dev) + your prod domain.
# Required redirect URIs: same.
# Docs: https://developers.google.com/identity/oauth2/web/guides/use-origin-model
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
