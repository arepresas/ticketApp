{
  "name": "ticketapp-front",
  "version": "0.0.1",
  "description": "Svelte 5 web components for ticketApp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite",
    "dev:landing": "vite --open /landing.html",
    "build": "vite build",
    "preview": "vite preview",
    "preview:landing": "vite preview --open /landing.html",
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text --coverage.reportsDirectory=coverage",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=reports/junit.xml",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "svelte-chartjs": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  }
}
